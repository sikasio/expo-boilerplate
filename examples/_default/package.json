    "expo": "~54.0.0",
    "expo-asset": "^12.0.10",
    "expo-blur": "~15.0.7",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.4",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.8",
