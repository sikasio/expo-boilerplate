{
  "name": "@sikasio/expo-boilerplate",
  "version": "0.1.0",
  "description": "Sikasio Expo/React Native boilerplate — UI, contexts, services, hooks, utils.",
  "license": "Apache-2.0",
  "author": "Sikasio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sikasio/expo-boilerplate.git"
  },
  "homepage": "https://github.com/sikasio/expo-boilerplate",
  "bugs": {
    "url": "https://github.com/sikasio/expo-boilerplate/issues"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "assets/fonts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./components/ui": {
      "import": "./dist/components/ui/index.js",
      "types": "./dist/components/ui/index.d.ts"
    },
    "./components/forms": {
      "import": "./dist/components/forms/index.js",
      "types": "./dist/components/forms/index.d.ts"
    },
    "./components/layout": {
      "import": "./dist/components/layout/index.js",
      "types": "./dist/components/layout/index.d.ts"
    },
    "./components/navigation": {
      "import": "./dist/components/navigation/index.js",
      "types": "./dist/components/navigation/index.d.ts"
    },
    "./components/overlays": {
      "import": "./dist/components/overlays/index.js",
      "types": "./dist/components/overlays/index.d.ts"
    },
    "./contexts": {
      "import": "./dist/contexts/index.js",
      "types": "./dist/contexts/index.d.ts"
    },
    "./services": {
      "import": "./dist/services/index.js",
      "types": "./dist/services/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./screens": {
      "import": "./dist/screens/index.js",
      "types": "./dist/screens/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./constants": {
      "import": "./dist/constants/index.js",
      "types": "./dist/constants/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./fonts/*": "./assets/fonts/*"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.4",
    "expo-haptics": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.7",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.7",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.16.0"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "@types/react": "~19.1.0",
    "@types/react-native": "^0.73.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "expo",
    "react-native",
    "boilerplate",
    "sikasio",
    "rtl",
    "arabic"
  ]
}
