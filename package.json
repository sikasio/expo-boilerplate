{
  "name": "@sikasio/expo-boilerplate",
  "version": "0.1.0",
  "description": "Sikasio Expo/React Native boilerplate — UI, contexts, services, hooks, utils.",
  "license": "Apache-2.0",
  "author": "Sikasio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sikasio/expo-boilerplate.git"
  },
  "homepage": "https://github.com/sikasio/expo-boilerplate",
  "bugs": {
    "url": "https://github.com/sikasio/expo-boilerplate/issues"
  },
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "files": [
    "src",
    "assets/fonts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components": "./src/components/index.ts",
    "./components/ui": "./src/components/ui/index.ts",
    "./components/forms": "./src/components/forms/index.ts",
    "./components/layout": "./src/components/layout/index.ts",
    "./components/navigation": "./src/components/navigation/index.ts",
    "./components/overlays": "./src/components/overlays/index.ts",
    "./contexts": "./src/contexts/index.ts",
    "./services": "./src/services/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./utils": "./src/utils/index.ts",
    "./screens": "./src/screens/index.ts",
    "./config": "./src/config/index.ts",
    "./constants": "./src/constants/index.ts",
    "./types": "./src/types/index.ts",
    "./fonts/*": "./assets/fonts/*"
  },
  "scripts": {
    "typecheck": "echo 'typecheck is a no-op for raw-source packages; consumers typecheck.'"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.4",
    "expo-haptics": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.7",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.7",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.16.0"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "expo",
    "react-native",
    "boilerplate",
    "sikasio",
    "rtl",
    "arabic"
  ]
}
