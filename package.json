{
  "name": "@sikasio/expo-boilerplate",
  "version": "0.1.12",
  "description": "Sikasio Expo/React Native boilerplate — UI, contexts, services, hooks, utils.",
  "license": "Apache-2.0",
  "author": "Sikasio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sikasio/expo-boilerplate.git"
  },
  "homepage": "https://github.com/sikasio/expo-boilerplate",
  "bugs": {
    "url": "https://github.com/sikasio/expo-boilerplate/issues"
  },
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "files": [
    "src",
    "assets/fonts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components": "./src/components/index.ts",
    "./components/ui": "./src/components/ui/index.ts",
    "./components/forms": "./src/components/forms/index.ts",
    "./components/layout": "./src/components/layout/index.ts",
    "./components/navigation": "./src/components/navigation/index.ts",
    "./components/overlays": "./src/components/overlays/index.ts",
    "./contexts": "./src/contexts/index.ts",
    "./services": "./src/services/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./utils": "./src/utils/index.ts",
    "./screens": "./src/screens/index.ts",
    "./config": "./src/config/index.ts",
    "./constants": "./src/constants/index.ts",
    "./types": "./src/types/index.ts",
    "./fonts/*": "./assets/fonts/*"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "echo 'typecheck is a no-op for raw-source packages; consumers typecheck.'"
  },
  "peerDependencies": {
    "@expo/vector-icons": ">=14.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.7",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.4",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.8",
    "expo-linking": "~8.0.8",
    "expo-notifications": "^0.32.11",
    "expo-router": "~6.0.7",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.7",
    "react": "19.1.0",
    "react-hook-form": "^7.61.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "^0.5.1"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "date-fns": "^4.1.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "expo",
    "expo-boilerplate",
    "expo-template",
    "expo-starter",
    "expo-router",
    "react-native",
    "react-native-boilerplate",
    "react-native-template",
    "react-native-starter",
    "react-native-ui",
    "ui-components",
    "ui-kit",
    "component-library",
    "theme",
    "dark-mode",
    "rtl",
    "arabic",
    "i18n",
    "auth-screen",
    "form-components",
    "react-hook-form",
    "async-storage",
    "typescript",
    "hooks",
    "boilerplate",
    "template",
    "starter",
    "mobile",
    "zain-font",
    "subpath-exports",
    "sikasio"
  ],
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  }
}
